generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
}

model admin {
  admin_id      String        @id @db.VarChar(50)
  title         String        @db.VarChar(50)
  name          String        @db.VarChar(100)
  lastname      String        @db.VarChar(100)
  email         String        @db.VarChar(100)
  tel           String        @db.VarChar(20)
  hash_password String        @db.VarChar(255)
  status        record_status
  updated_at    DateTime      @db.Timestamp(6)
  created_at    DateTime      @db.Timestamp(6)
}

model customer_wallet {
  trans_id               String                  @db.VarChar(50)
  branch_id              String                  @db.VarChar(50)
  clinic_id              String                  @db.VarChar(50)
  customer_id            String                  @db.VarChar(50)
  date                   DateTime                @db.Timestamp(6)
  payment_method_id      String                  @db.VarChar(50)
  amount                 Decimal                 @db.Decimal(10, 2)
  bonus                  Decimal                 @db.Decimal(10, 2)
  seller_id              String                  @db.VarChar(50)
  cashier_id             String                  @db.VarChar(50)
  remark                 String?
  evidence               String
  status                 record_status
  updated_at             DateTime                @db.Timestamp(6)
  created_at             DateTime                @db.Timestamp(6)
  created_by             String?                 @db.VarChar(50)
  branch                 branch                  @relation(fields: [branch_id], references: [branch_id])
  cashier_detail         user                    @relation("cashier_detail", fields: [cashier_id], references: [user_id])
  created_by_user        user?                   @relation("created_by_user", fields: [created_by], references: [user_id])
  customer               customer                @relation(fields: [customer_id, clinic_id], references: [customer_id, clinic_id])
  payment_method         clinic_payment_method   @relation(fields: [payment_method_id], references: [clinic_payment_method_id])
  seller_detail          user                    @relation("seller_detail_user", fields: [seller_id], references: [user_id])
  sale_wallet_commission sale_wallet_commission?

  @@id([trans_id, branch_id])
  @@index([customer_id, clinic_id])
  @@index([payment_method_id])
  @@index([branch_id])
  @@index([seller_id])
}

model wallet_log {
  wallet_log_id String      @id @db.VarChar(50)
  branch_id     String      @db.VarChar(50)
  clinic_id     String      @db.VarChar(50)
  reference_id  String?     @db.VarChar(50)
  customer_id   String      @db.VarChar(50)
  in            Decimal     @db.Decimal(10, 2)
  out           Decimal     @db.Decimal(10, 2)
  type          wallet_type @default(NORMAL)
  updated_at    DateTime    @db.Timestamp(6)
  created_at    DateTime    @db.Timestamp(6)
  customer      customer    @relation(fields: [customer_id, clinic_id], references: [customer_id, clinic_id])

  @@index([reference_id, branch_id])
  @@index([customer_id, clinic_id])
}

model appointment {
  appointment_id        String                  @id @db.VarChar(50)
  branch_id             String                  @db.VarChar(50)
  clinic_id             String                  @db.VarChar(50)
  customer_id           String                  @db.VarChar(50)
  user_create           String                  @db.VarChar(50)
  room                  String?                 @db.VarChar(50)
  date_appointment      String                  @db.VarChar(50)
  time_arrive           String                  @db.VarChar(20)
  start_time            String                  @db.VarChar(20)
  end_time              String                  @db.VarChar(20)
  channel               String?                 @db.VarChar(120)
  is_consult            Boolean
  apply_anesthetic      Boolean
  appointment_detail    String?
  status_appointment    statusAppointment
  updated_at            DateTime                @db.Timestamp(6)
  created_at            DateTime                @db.Timestamp(6)
  opd_id                String?
  branch                branch                  @relation(fields: [branch_id], references: [branch_id])
  customer              customer                @relation(fields: [customer_id, clinic_id], references: [customer_id, clinic_id])
  opd                   opd?                    @relation(fields: [opd_id, branch_id], references: [opd_id, branch_id])
  examination_room      examination_room?       @relation(fields: [room], references: [room_id])
  operation_appointment operation_appointment[]
  user_appointment      user_appointment[]
}

model appointment_detail_extra {
  appointment_id     String   @id @db.VarChar(50)
  clinic_id          String   @db.VarChar(50)
  branch_id          String   @db.VarChar(50)
  marketing_platform String?  @db.VarChar(120)
  campaign           String?  @db.VarChar(120)
  numbing_time       Int?
  preparation        String?
  preparation_tags   Json?
  internal_note      String?
  internal_tags      Json?
  notifications      Json?
  recurring          Json?
  created_by         String?  @db.VarChar(50)
  updated_at         DateTime @db.Timestamp(6)
  created_at         DateTime @default(now()) @db.Timestamp(6)

  @@index([clinic_id, branch_id])
}

model user_appointment {
  appointment_id String        @db.VarChar(50)
  user_id        String        @db.VarChar(50)
  operator_type  operator_type @default(OPERATOR)
  appointment    appointment   @relation(fields: [appointment_id], references: [appointment_id])
  user           user          @relation(fields: [user_id], references: [user_id])

  @@id([appointment_id, user_id, operator_type])
}

model operation_appointment {
  appointment_id String         @db.VarChar(50)
  product_id     String         @db.VarChar(50)
  appointment    appointment    @relation(fields: [appointment_id], references: [appointment_id])
  operation_item operation_item @relation(fields: [product_id], references: [op_id])

  @@id([appointment_id, product_id])
}

model appointment_reminder {
  reminder_id     String       @id @db.VarChar(50)
  branch_id       String       @db.VarChar(50)
  clinic_id       String       @db.VarChar(50)
  customer_id     String       @db.VarChar(50)
  user_create     String       @db.VarChar(50)
  date_reminder   String       @db.VarChar(50)
  reminder_detail String?
  updated_at      DateTime     @db.Timestamp(6)
  created_at      DateTime     @db.Timestamp(6)
  text_repeat     String?
  status_reminder statusRemind
  opd_id          String?
  reference_id    String?      @db.VarChar(50)
  item_id         String?
  branch          branch       @relation(fields: [branch_id], references: [branch_id])
  customer        customer     @relation(fields: [customer_id, clinic_id], references: [customer_id, clinic_id])
  opd             opd?         @relation(fields: [opd_id, branch_id], references: [opd_id, branch_id])
  user            user         @relation(fields: [user_create], references: [user_id])
}

model branch {
  branch_id                    String                         @id @db.VarChar(50)
  clinic_id                    String                         @db.VarChar(50)
  branch_logo                  String
  document_logo                String?
  branch_name                  String                         @db.VarChar(250)
  fax                          String?                        @db.VarChar(20)
  tel                          String?                        @db.VarChar(20)
  license_no                   String                         @db.VarChar(50)
  tax_id                       String?                        @db.VarChar(50)
  email                        String                         @db.VarChar(100)
  line_id                      String                         @db.VarChar(100)
  address                      String                         @db.VarChar(250)
  sub_district                 String                         @db.VarChar(100)
  district                     String                         @db.VarChar(100)
  province                     String                         @db.VarChar(100)
  postcode                     String                         @db.VarChar(5)
  status                       record_status
  round_decimal                Boolean
  sales_tax                    vat_type
  purchase_tax                 vat_type
  condition_wallet             condition_wallet_enum
  percent_commission           Decimal                        @db.Decimal(5, 2)
  document_form_id             String                         @db.VarChar(50)
  type_branch                  type_branch                    @default(NORMAL)
  updated_at                   DateTime                       @db.Timestamp(6)
  created_at                   DateTime                       @db.Timestamp(6)
  branch_no                    String                         @db.VarChar(10)
  is_upload_image_course       Boolean                        @default(false)
  appointment                  appointment[]
  appointment_reminder         appointment_reminder[]
  clinic                       clinic                         @relation(fields: [clinic_id], references: [clinic_id])
  document_form                document_form                  @relation(fields: [document_form_id], references: [form_id])
  bundle_set                   bundle_set[]
  clinic_payment_method        clinic_payment_method[]
  course                       course[]
  customer                     customer[]
  customer_attendant           customer_attendant[]
  customer_registration        customer_registration[]
  customer_wallet              customer_wallet[]
  distributor                  distributor[]
  document_format              document_format[]
  examination_room             examination_room[]
  opd                          opd[]
  operation_item               operation_item[]
  prescription                 prescription[]
  product                      product[]
  sale_order                   sale_order[]
  sale_target                  sale_target[]
  service_usage                service_usage[]
  service_usage_expiration     service_usage_expiration[]
  service_usage_request_cancel service_usage_request_cancel[]
  transfer_order               transfer_order[]
  user_branch                  user_branch[]
  user_permission              user_permission[]
  work_schedule                work_schedule[]

  @@index([branch_id, clinic_id])
}

model bundle_set {
  bundle_set_id                   String                            @id @db.VarChar(50)
  bundle_set_id_display           String                            @db.VarChar(100)
  branch_id                       String                            @db.VarChar(50)
  bundle_set_name                 String                            @db.VarChar(250)
  status                          record_status
  description                     String?
  vat                             vat_type
  unit                            String                            @db.VarChar(250)
  total_price                     Decimal                           @db.Decimal(10, 2)
  start_date                      DateTime?                         @db.Timestamp(6)
  end_date                        DateTime?                         @db.Timestamp(6)
  updated_at                      DateTime                          @db.Timestamp(6)
  created_at                      DateTime                          @db.Timestamp(6)
  branch                          branch                            @relation(fields: [branch_id], references: [branch_id])
  bundle_set_course_item          bundle_set_course_item[]
  bundle_set_product_item         bundle_set_product_item[]
  sale_order_item                 sale_order_item[]
  sale_order_item_bundle_set_item sale_order_item_bundle_set_item[]
}

model bundle_set_product_item {
  bundle_set_id   String               @db.VarChar(50)
  item_id         String               @db.VarChar(50)
  quantity        Decimal              @db.Decimal(10, 2)
  price           Decimal              @db.Decimal(10, 2)
  promotion_price Decimal              @db.Decimal(10, 2)
  type            all_product_category
  updated_at      DateTime             @db.Timestamp(6)
  created_at      DateTime             @db.Timestamp(6)
  product         product              @relation(fields: [item_id], references: [product_id], map: "bundle_set_item_product")
  bundle_set      bundle_set           @relation(fields: [bundle_set_id], references: [bundle_set_id])

  @@id([bundle_set_id, item_id])
}

model bundle_set_course_item {
  bundle_set_id   String               @db.VarChar(50)
  item_id         String               @db.VarChar(50)
  quantity        Decimal              @db.Decimal(10, 2)
  price           Decimal              @db.Decimal(10, 2)
  promotion_price Decimal              @db.Decimal(10, 2)
  type            all_product_category
  updated_at      DateTime             @db.Timestamp(6)
  created_at      DateTime             @db.Timestamp(6)
  bundle_set      bundle_set           @relation(fields: [bundle_set_id], references: [bundle_set_id])
  course_item     course_item          @relation(fields: [item_id], references: [course_item_id])

  @@id([bundle_set_id, item_id])
}

model category {
  category_id      String               @id @db.VarChar(50)
  clinic_id        String               @db.VarChar(50)
  name             String               @db.VarChar(250)
  product_category all_product_category
  updated_at       DateTime             @db.Timestamp(6)
  created_at       DateTime             @db.Timestamp(6)
  status           record_status        @default(ACTIVE)
  code             String?              @db.VarChar(50)
  clinic           clinic               @relation(fields: [clinic_id], references: [clinic_id])
  course           course[]
  product          product[]
  voucher_category voucher_category[]
}

model clinic {
  clinic_id                            String                                 @id @db.VarChar(50)
  clinic_name                          String?                                @db.VarChar(200)
  clinic_logo                          String?
  tel                                  String                                 @db.VarChar(20)
  email                                String                                 @db.VarChar(100)
  status                               record_status
  status_send_password                 Boolean                                @default(false)
  updated_at                           DateTime?                              @db.Timestamp(6)
  created_at                           DateTime?                              @db.Timestamp(6)
  is_upload_image_course               Boolean                                @default(false)
  is_sync_with_erp                     Boolean                                @default(false)
  branch                               branch[]
  category                             category[]
  clinic_subscription                  clinic_subscription[]
  clinic_to_clinic_transfer_white_list clinic_to_clinic_transfer_white_list[]
  condition_wallet                     condition_wallet[]
  customer                             customer[]
  customer_group                       customer_group[]
  customer_registration                customer_registration[]
  diagnosis_item                       diagnosis_item[]
  distributor                          distributor[]
  documents_signed                     documents_signed[]
  sub_category                         sub_category[]
  template_detail                      template_detail[]
  user                                 user[]
}

model clinic_payment_method {
  clinic_payment_method_id String                  @id @db.VarChar(50)
  branch_id                String                  @db.VarChar(50)
  name                     String                  @db.VarChar(250)
  payment_type             clinic_payment_type
  status                   record_status
  created_by               String                  @db.VarChar(50)
  updated_at               DateTime                @db.Timestamp(6)
  created_at               DateTime                @db.Timestamp(6)
  code                     String?                 @db.VarChar(50)
  branch                   branch                  @relation(fields: [branch_id], references: [branch_id])
  customer_wallet          customer_wallet[]
  receipt                  receipt[]
  receive_order_receipt    receive_order_receipt[]
}

model clinic_registration {
  registration_id      String                       @id @db.VarChar(50)
  clinic_name          String?                      @db.VarChar(200)
  clinic_logo          String?
  license_no           String                       @db.VarChar(50)
  tax_id               String                       @db.VarChar(50)
  fax                  String?                      @db.VarChar(20)
  tel                  String                       @db.VarChar(20)
  email                String                       @db.VarChar(100)
  line_id              String?                      @db.VarChar(100)
  address              String                       @db.VarChar(250)
  sub_district         String                       @db.VarChar(100)
  district             String                       @db.VarChar(100)
  province             String                       @db.VarChar(100)
  postcode             String                       @db.VarChar(5)
  status               record_status
  registration_status  approved_status?
  subscription_plan_id String?                      @db.VarChar(50)
  receipt_id           String?                      @db.VarChar(50)
  updated_at           DateTime?                    @db.Timestamp(6)
  created_at           DateTime?                    @db.Timestamp(6)
  receipt              clinic_subscription_receipt? @relation(fields: [receipt_id], references: [receipt_id])
  subscription_plan    subscription_plan?           @relation(fields: [subscription_plan_id], references: [plan_id])
}

model clinic_subscription {
  subscription_id             String                       @id @db.VarChar(50)
  clinic_id                   String                       @db.VarChar(50)
  year                        Int
  subscription_plan_id        String                       @db.VarChar(50)
  receipt_id                  String?                      @db.VarChar(50)
  plan_name_th                String                       @db.VarChar(100)
  plan_name_en                String                       @db.VarChar(100)
  end_date                    DateTime                     @db.Timestamp(6)
  start_date                  DateTime                     @db.Timestamp(6)
  price                       Decimal                      @db.Decimal(10, 4)
  status                      record_status
  payment_status              payment_status
  updated_at                  DateTime                     @db.Timestamp(6)
  created_at                  DateTime                     @db.Timestamp(6)
  clinic                      clinic                       @relation(fields: [clinic_id], references: [clinic_id])
  clinic_subscription_receipt clinic_subscription_receipt? @relation(fields: [receipt_id], references: [receipt_id])
  subscription_plan           subscription_plan            @relation(fields: [subscription_plan_id], references: [plan_id])
}

model clinic_subscription_receipt {
  receipt_id          String                @id @db.VarChar(50)
  receipt             String
  evidence            String
  amount_pay          Decimal?              @db.Decimal(10, 2)
  payment_method_id   String?               @db.VarChar(50)
  payment_date        DateTime?             @db.Timestamp(6)
  updated_at          DateTime?             @db.Timestamp(6)
  created_at          DateTime?             @db.Timestamp(6)
  clinic_registration clinic_registration[]
  clinic_subscription clinic_subscription[]
  payment_method      payment_method?       @relation(fields: [payment_method_id], references: [method_id])
}

model sale_receipt_commission {
  sale_order_id     String     @db.VarChar(50)
  branch_id         String     @db.VarChar(50)
  reciept_id        String     @db.VarChar(50)
  user_id           String?    @db.VarChar(50)
  calculate_percent Decimal?   @db.Decimal(10, 2)
  shared            Decimal?   @db.Decimal(10, 2)
  Sales             Decimal?   @db.Decimal(10, 2)
  updated_at        DateTime?  @db.Timestamp(6)
  created_at        DateTime?  @db.Timestamp(6)
  receipt           receipt    @relation(fields: [reciept_id, branch_id], references: [receipt_id, branch_id])
  sale_order        sale_order @relation(fields: [sale_order_id, branch_id], references: [sale_order_id, branch_id])

  @@id([sale_order_id, reciept_id, branch_id])
}

model sale_wallet_commission {
  trans_id          String          @db.VarChar(50)
  branch_id         String          @db.VarChar(50)
  user_id           String?         @db.VarChar(50)
  calculate_percent Decimal?        @db.Decimal(10, 2)
  shared            Decimal?        @db.Decimal(10, 2)
  Sales             Decimal?        @db.Decimal(10, 2)
  updated_at        DateTime?       @db.Timestamp(6)
  created_at        DateTime?       @db.Timestamp(6)
  wallet            customer_wallet @relation(fields: [trans_id, branch_id], references: [trans_id, branch_id])

  @@id([trans_id, branch_id])
}

model condition_wallet {
  condition_id    String                @id @db.VarChar(50)
  clinic_id       String                @db.VarChar(50)
  bonus           Decimal               @db.Decimal(10, 2)
  bonus_type      type_condition_wallet
  status          record_status
  minimum_balance Decimal               @db.Decimal(10, 2)
  maximum_balance Decimal               @db.Decimal(10, 2)
  updated_at      DateTime              @db.Timestamp(6)
  created_at      DateTime              @db.Timestamp(6)
  clinic          clinic                @relation(fields: [clinic_id], references: [clinic_id])
}

model course_item {
  course_item_id                  String                            @id @db.VarChar(50)
  course_id                       String                            @db.VarChar(50)
  unit                            String                            @default("-") @db.VarChar(50)
  name                            String                            @db.VarChar(256)
  price                           Decimal                           @db.Decimal(10, 2)
  amount                          Decimal                           @default(0) @db.Decimal(10, 2)
  vat                             vat_type
  start_date                      DateTime?                         @db.Timestamp(6)
  end_date                        DateTime?                         @db.Timestamp(6)
  promotion_price                 Decimal?                          @db.Decimal(10, 2)
  created_by                      String                            @db.VarChar(50)
  updated_at                      DateTime                          @db.Timestamp(6)
  created_at                      DateTime                          @db.Timestamp(6)
  appointment_alert               Int?
  appointment_alert_unit          date_unit?
  time_per_course                 Decimal?                          @db.Decimal(10, 2)
  weight_per_time                 Decimal?                          @db.Decimal(10, 2)
  status                          record_status                     @default(ACTIVE)
  bundle_set_course_item          bundle_set_course_item[]
  give_away_course_item           course_give_away[]
  course                          course                            @relation(fields: [course_id], references: [course_id])
  course_item_product             course_item_product[]
  customer_coures                 customer_coures[]
  customer_course_usage_log       customer_course_usage_log[]
  product_course_give_away        product_course_give_away[]
  sale_order_item                 sale_order_item[]
  sale_order_item_bundle_set_item sale_order_item_bundle_set_item[]
  service_usage_expiration_item   service_usage_expiration_item[]
  service_usage_item              service_usage_item[]
}

model course_item_product {
  product_id     String      @db.VarChar(50)
  course_item_id String      @db.VarChar(50)
  quantity       Decimal     @db.Decimal(10, 2)
  updated_at     DateTime    @db.Timestamp(6)
  created_at     DateTime    @db.Timestamp(6)
  course_item    course_item @relation(fields: [course_item_id], references: [course_item_id])
  product        product     @relation(fields: [product_id], references: [product_id])

  @@id([product_id, course_item_id])
}

model course_operator {
  course_id       String        @db.VarChar(50)
  role_id         role_enum
  commission      Decimal       @db.Decimal(10, 2)
  commission_unit amount_unit
  operator_type   operator_type
  course          course        @relation(fields: [course_id], references: [course_id])
  role            role          @relation(fields: [role_id], references: [role_id])

  @@id([course_id, role_id, operator_type])
}

model course_operator_user {
  service_usage_id String        @db.VarChar(50)
  user_id          String        @db.VarChar(50)
  branch_id        String        @db.VarChar(50)
  operator_type    operator_type
  service_usage    service_usage @relation(fields: [service_usage_id, branch_id], references: [service_usage_id, branch_id])
  user             user          @relation(fields: [user_id], references: [user_id])

  @@id([service_usage_id, user_id, operator_type])
  @@index([user_id, branch_id])
  @@index([user_id])
  @@index([branch_id])
}

model customer {
  customer_id               String                      @db.VarChar(50)
  clinic_id                 String                      @db.VarChar(50)
  branch_id                 String                      @db.VarChar(50)
  title                     String                      @db.VarChar(30)
  name                      String                      @db.VarChar(100)
  lastname                  String                      @db.VarChar(100)
  nickname                  String?                     @db.VarChar(50)
  gender                    String                      @db.VarChar(20)
  birth_date                String?                     @db.VarChar(50)
  personal_id               String                      @db.VarChar(20)
  status_marry              String?                     @db.VarChar(100)
  address                   String?                     @db.VarChar(300)
  sub_district              String?                     @db.VarChar(200)
  district                  String?                     @db.VarChar(200)
  province                  String?                     @db.VarChar(200)
  postcode                  String?                     @db.VarChar(50)
  phone_number              String?                     @db.VarChar(15)
  second_phone_number       String?                     @db.VarChar(15)
  attendant                 String?                     @db.VarChar(100)
  email                     String?                     @db.VarChar(200)
  line_id                   String?                     @db.VarChar(250)
  customer_image            String?
  customer_status           Boolean
  status_vip                Boolean
  customer_group            String?                     @db.VarChar(50)
  point_accumulate_all_old  Decimal?                    @db.Decimal(10, 2)
  point_current_year        Decimal?                    @db.Decimal(10, 2)
  user_create               String                      @db.VarChar(50)
  updated_at                DateTime?                   @db.Timestamp(6)
  created_at                DateTime?                   @db.Timestamp(6)
  nationality               nationality                 @default(THAI)
  ethnicity                 String?                     @db.VarChar(100)
  appointment               appointment[]
  appointment_reminder      appointment_reminder[]
  attendant_detail          user?                       @relation(fields: [attendant], references: [user_id])
  branch_register           branch                      @relation(fields: [branch_id], references: [branch_id])
  clinic                    clinic                      @relation(fields: [clinic_id], references: [clinic_id])
  customer_group_info       customer_group?             @relation(fields: [customer_group], references: [group_id])
  customer_attendant        customer_attendant[]
  customer_coures           customer_coures[]
  customer_course_usage_log customer_course_usage_log[]
  customer_file             customer_file[]
  customer_info             customer_info?
  customer_note             customer_note[]
  customer_wallet           customer_wallet[]
  documents_signed_customer documents_signed_customer[]
  history_customer_group    history_customer_group[]
  opd                       opd[]
  prescription              prescription[]
  sale_order                sale_order[]
  service_usage             service_usage[]             @relation("service_usage")
  service_usage_owner       service_usage[]             @relation("service_usage_owner")
  service_usage_expiration  service_usage_expiration[]
  wallet_log                wallet_log[]

  @@id([customer_id, clinic_id])
  @@index([attendant])
  @@index([customer_group])
  @@index([clinic_id])
  @@index([branch_id])
}

model customer_info {
  customer_id                String   @db.VarChar(50)
  clinic_id                  String   @db.VarChar(50)
  allergy                    String?
  surgery                    String?
  congenital_disease         String?
