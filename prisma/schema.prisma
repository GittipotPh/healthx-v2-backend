  encounter            opd_encounter   @relation(fields: [encounter_id, clinic_id, branch_id], references: [encounter_id, clinic_id, branch_id], onDelete: Restrict, onUpdate: Cascade, map: "opd_diagnosis_section_encounter_tenant_fkey")
