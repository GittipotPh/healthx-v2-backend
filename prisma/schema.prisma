  branch_id         String             @db.VarChar(50)
  encounter_id      String             @db.Uuid
  selected_mode     String             @default("FORM") @db.VarChar(10)
  version           Int                @default(1)
  created_by        String             @db.VarChar(50)
  updated_by        String             @db.VarChar(50)
  created_at        DateTime           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
  encounter         opd_encounter      @relation(fields: [encounter_id, clinic_id, branch_id], references: [encounter_id, clinic_id, branch_id], onDelete: Restrict, onUpdate: Cascade, map: "opd_note_workspace_encounter_tenant_fkey")
  sections          opd_note_section[]

  @@unique([note_workspace_id, clinic_id, branch_id, encounter_id], map: "opd_note_workspace_identity_uq")
  @@unique([encounter_id, clinic_id, branch_id], map: "opd_note_workspace_encounter_uq")
  @@index([clinic_id, branch_id, encounter_id], map: "opd_note_workspace_scope_idx")
}

// Independently versioned clinical note content. rich_content contains only the
// restricted clinical-rich-text-v1 JSON AST; plain_text is derived server-side.
model opd_note_section {
  note_section_id   String             @id @default(uuid()) @db.Uuid
  clinic_id         String             @db.VarChar(50)
  branch_id         String             @db.VarChar(50)
  encounter_id      String             @db.Uuid
  note_workspace_id String             @db.Uuid
  section_code      String             @db.VarChar(40)
  content_schema    String             @default("clinical-rich-text-v1") @db.VarChar(40)
  rich_content      Json
  plain_text        String             @default("") @db.Text
  status            String             @default("DRAFT") @db.VarChar(20)
  version           Int                @default(1)
  created_by        String             @db.VarChar(50)
  updated_by        String             @db.VarChar(50)
  created_at        DateTime           @default(now()) @db.Timestamptz(6)
  updated_at        DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
  note_workspace    opd_note_workspace @relation(fields: [note_workspace_id, clinic_id, branch_id, encounter_id], references: [note_workspace_id, clinic_id, branch_id, encounter_id], onDelete: Restrict, onUpdate: Cascade, map: "opd_note_section_workspace_identity_fkey")

  @@unique([note_section_id, clinic_id, branch_id, encounter_id], map: "opd_note_section_identity_uq")
  @@unique([note_workspace_id, section_code], map: "opd_note_section_workspace_code_uq")
  @@index([clinic_id, branch_id, encounter_id, section_code, status], map: "opd_note_section_encounter_idx")
}

