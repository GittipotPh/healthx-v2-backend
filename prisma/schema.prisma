// App-owned transactional outbox (plan-latest §8 / rabbitmq plan §3): services
// insert a row inside the same $transaction as the business write; the
// dispatcher publishes PENDING rows to RabbitMQ with publisher confirms.
// String refs to HealthX rows only — NO @relation/FK to legacy tables.
model outbox_event {
  id             String    @id @default(uuid()) @db.Uuid
  event_type     String    @db.VarChar(100) // e.g. "erp.sales-order.created"
  aggregate_type String    @db.VarChar(50) // e.g. "sale_order"
  aggregate_id   String    @db.VarChar(50)
  clinic_id      String    @db.VarChar(50)
  branch_id      String?   @db.VarChar(50)
  payload        Json
  correlation_id String    @db.VarChar(64)
  status         String    @default("PENDING") @db.VarChar(20) // PENDING | PUBLISHED | PARKED
  attempts       Int       @default(0)
  created_at     DateTime  @default(now()) @db.Timestamp(6)
  published_at   DateTime? @db.Timestamp(6)

  @@index([status, created_at])
}

// Idempotent record of BC->HealthX commands applied through the internal
// x-service-key command API (plan-latest §4). command_id is the erp-integration
// service's inbound idempotency key; the unique constraint makes replays no-ops.
model erp_inbound_command {
  erp_inbound_command_id String   @id @default(uuid()) @db.Uuid
  operation              String   @db.VarChar(100)
  command_id             String   @db.VarChar(200)
  branch_id              String   @db.VarChar(50)
  payload                Json
  correlation_id         String?  @db.VarChar(100)
  result                 String   @default("RECORDED") @db.VarChar(20)
  received_at            DateTime @default(now()) @db.Timestamp(6)

  @@unique([operation, command_id])
  @@index([received_at])
}

// App-owned stable worklist identity for appointment and walk-in OPD visits.
// HealthX-owned customer/appointment/user rows are string references only.
model opd_queue_ticket {
  queue_ticket_id        String                @id @default(uuid()) @db.Uuid
  clinic_id              String                @db.VarChar(50)
  branch_id              String                @db.VarChar(50)
  customer_id            String                @db.VarChar(50)
  appointment_id         String?               @db.VarChar(50)
  legacy_queue_status_id String?               @db.Uuid
  source_type            String                @db.VarChar(20)
  business_date          DateTime              @db.Date
  current_step           String                @db.VarChar(30)
  entered_at             DateTime              @db.Timestamptz(6)
  queue_sequence         Int
  display_number         String                @db.VarChar(30)
  version                Int                   @default(1)
  cancelled_at           DateTime?             @db.Timestamptz(6)
  cancelled_by           String?               @db.VarChar(50)
  cancellation_reason    String?               @db.VarChar(500)
  created_by             String                @db.VarChar(50)
  created_at             DateTime              @default(now()) @db.Timestamptz(6)
  updated_at             DateTime              @default(now()) @updatedAt @db.Timestamptz(6)
  step                   ref_queue_step_status @relation(fields: [current_step], references: [code], onDelete: Restrict, onUpdate: Cascade, map: "opd_queue_ticket_current_step_fkey")
  encounter              opd_encounter?
  transitions            queue_transition[]

  @@unique([queue_ticket_id, clinic_id, branch_id], map: "opd_queue_ticket_tenant_uq")
  @@unique([queue_ticket_id, clinic_id, branch_id, customer_id, business_date], map: "opd_queue_ticket_encounter_identity_uq")
  @@unique([clinic_id, branch_id, appointment_id], map: "opd_queue_ticket_appointment_uq")
  @@unique([clinic_id, branch_id, business_date, queue_sequence], map: "opd_queue_ticket_daily_seq_uq")
  @@unique([clinic_id, branch_id, business_date, display_number], map: "opd_queue_ticket_display_no_uq")
  @@index([clinic_id, branch_id, business_date, current_step], map: "opd_queue_ticket_worklist_idx")
  @@index([clinic_id, branch_id, customer_id, business_date], map: "opd_queue_ticket_customer_idx")
}

// Row-level counter allocated under a lock/atomic increment. The period key is
// interpreted by number_kind policy (daily queue uses YYYYMMDD Bangkok date).
model opd_number_sequence {
  number_sequence_id String   @id @default(uuid()) @db.Uuid
  clinic_id          String   @db.VarChar(50)
  branch_id          String   @db.VarChar(50)
  number_kind        String   @db.VarChar(30)
  period_key         String   @db.VarChar(30)
  next_value         BigInt   @default(1)
  version            Int      @default(1)
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at         DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@unique([clinic_id, branch_id, number_kind, period_key], map: "opd_number_sequence_scope_uq")
}

// OPD V2 aggregate. All HealthX-owned references deliberately remain scalar
// strings; queue_ticket is an app-owned, tenant-safe relation.
model opd_encounter {
  encounter_id           String                 @id @default(uuid()) @db.Uuid
  clinic_id              String                 @db.VarChar(50)
  branch_id              String                 @db.VarChar(50)
  customer_id            String                 @db.VarChar(50)
  appointment_id         String?                @db.VarChar(50)
  queue_ticket_id        String                 @db.Uuid
  legacy_opd_id          String?                @db.VarChar(50)
  attending_user_id      String?                @db.VarChar(50)
  encounter_type         String                 @db.VarChar(20)
  workflow_status        String                 @default("OPEN") @db.VarChar(20)
  clinical_record_status String                 @default("DRAFT") @db.VarChar(20)
  reconciliation_status  String                 @default("RECONCILED") @db.VarChar(20)
  business_date          DateTime               @db.Date
  started_at             DateTime               @db.Timestamptz(6)
  started_by             String                 @db.VarChar(50)
  finalized_at           DateTime?              @db.Timestamptz(6)
  finalized_by           String?                @db.VarChar(50)
  closed_at              DateTime?              @db.Timestamptz(6)
  closed_by              String?                @db.VarChar(50)
  cancelled_at           DateTime?              @db.Timestamptz(6)
  cancelled_by           String?                @db.VarChar(50)
  close_reason           String?                @db.VarChar(500)
  cancellation_reason    String?                @db.VarChar(500)
  version                Int                    @default(1)
  created_at             DateTime               @default(now()) @db.Timestamptz(6)
  updated_at             DateTime               @default(now()) @updatedAt @db.Timestamptz(6)
  queue_ticket           opd_queue_ticket       @relation(fields: [queue_ticket_id, clinic_id, branch_id, customer_id, business_date], references: [queue_ticket_id, clinic_id, branch_id, customer_id, business_date], onDelete: Restrict, onUpdate: Cascade, map: "opd_encounter_ticket_identity_fkey")
  transitions            queue_transition[]
  draft_checkpoints      opd_draft_checkpoint[]
  examinations           opd_examination[]
  diagnosis_section      opd_diagnosis_section?
  note_workspace         opd_note_workspace?

  @@unique([encounter_id, clinic_id, branch_id], map: "opd_encounter_tenant_uq")
  @@unique([queue_ticket_id, clinic_id, branch_id], map: "opd_encounter_queue_ticket_uq")
  @@unique([queue_ticket_id, clinic_id, branch_id, customer_id, business_date], map: "opd_encounter_ticket_identity_uq")
  @@unique([clinic_id, branch_id, legacy_opd_id], map: "opd_encounter_legacy_opd_uq")
  @@index([clinic_id, branch_id, business_date, workflow_status], map: "opd_encounter_worklist_idx")
  @@index([clinic_id, branch_id, customer_id, business_date], map: "opd_encounter_customer_idx")
  @@index([clinic_id, branch_id, appointment_id], map: "opd_encounter_appointment_idx")
}

// Immutable history of queue-step changes. expected/result version makes one
// transition per ticket version enforceable even across retries.
model queue_transition {
  queue_transition_id String           @id @default(uuid()) @db.Uuid
  clinic_id           String           @db.VarChar(50)
  branch_id           String           @db.VarChar(50)
  queue_ticket_id     String           @db.Uuid
  encounter_id        String?          @db.Uuid
  appointment_id      String?          @db.VarChar(50)
  from_step           String           @db.VarChar(30)
  to_step             String           @db.VarChar(30)
  actor_user_id       String           @db.VarChar(50)
  reason              String?          @db.VarChar(500)
  expected_version    Int
  result_version      Int
  occurred_at         DateTime         @default(now()) @db.Timestamptz(6)
  queue_ticket        opd_queue_ticket @relation(fields: [queue_ticket_id, clinic_id, branch_id], references: [queue_ticket_id, clinic_id, branch_id], onDelete: Restrict, onUpdate: Cascade, map: "queue_transition_ticket_tenant_fkey")
  encounter           opd_encounter?   @relation(fields: [encounter_id, clinic_id, branch_id], references: [encounter_id, clinic_id, branch_id], onDelete: Restrict, onUpdate: Cascade, map: "queue_transition_encounter_tenant_fkey")

  @@unique([clinic_id, branch_id, queue_ticket_id, result_version], map: "queue_transition_ticket_version_uq")
  @@index([clinic_id, branch_id, encounter_id, occurred_at], map: "queue_transition_encounter_idx")
  @@index([clinic_id, branch_id, appointment_id, occurred_at], map: "queue_transition_appointment_idx")
}

// Scoped command-idempotency claim/result. result_snapshot is deliberately a
// minimal ID/status/version response, never a duplicate clinical payload.
model api_idempotency {
  api_idempotency_id String    @id @default(uuid()) @db.Uuid
  clinic_id          String    @db.VarChar(50)
  branch_id          String    @db.VarChar(50)
  actor_user_id      String    @db.VarChar(50)
  operation          String    @db.VarChar(100)
  idempotency_key    String    @db.VarChar(200)
  request_hash       String    @db.VarChar(64)
  state              String    @default("IN_PROGRESS") @db.VarChar(20)
  locked_at          DateTime  @default(now()) @db.Timestamptz(6)
  lock_expires_at    DateTime  @db.Timestamptz(6)
  resource_type      String?   @db.VarChar(50)
  resource_id        String?   @db.VarChar(100)
  result_snapshot    Json?
  response_code      Int?
  completed_at       DateTime? @db.Timestamptz(6)
  expires_at         DateTime  @db.Timestamptz(6)
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
  updated_at         DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  @@unique([clinic_id, branch_id, actor_user_id, operation, idempotency_key], map: "api_idempotency_scope_key_uq")
  @@index([state, lock_expires_at], map: "api_idempotency_lock_idx")
  @@index([expires_at], map: "api_idempotency_expiry_idx")
  @@index([clinic_id, branch_id, resource_type, resource_id], map: "api_idempotency_resource_idx")
}

// Explicit user save boundary; section content remains in its own versioned
// resources and this row stores only their version manifest.
model opd_draft_checkpoint {
  draft_checkpoint_id String        @id @default(uuid()) @db.Uuid
  clinic_id           String        @db.VarChar(50)
  branch_id           String        @db.VarChar(50)
  encounter_id        String        @db.Uuid
  checkpoint_number   Int
  resource_versions   Json
  actor_user_id       String        @db.VarChar(50)
  note                String?       @db.VarChar(500)
  created_at          DateTime      @default(now()) @db.Timestamptz(6)
  encounter           opd_encounter @relation(fields: [encounter_id, clinic_id, branch_id], references: [encounter_id, clinic_id, branch_id], onDelete: Restrict, onUpdate: Cascade, map: "opd_draft_checkpoint_encounter_tenant_fkey")

  @@unique([clinic_id, branch_id, encounter_id, checkpoint_number], map: "opd_draft_checkpoint_number_uq")
  @@index([clinic_id, branch_id, encounter_id, created_at], map: "opd_draft_checkpoint_created_idx")
}

// Versioned Phase 2 vital-examination aggregate. Legacy HealthX identifiers
// remain scalar strings; the only relation is to the app-owned OPD encounter.
model opd_examination {
  examination_id            String                 @id @default(uuid()) @db.Uuid
  clinic_id                 String                 @db.VarChar(50)
  branch_id                 String                 @db.VarChar(50)
  encounter_id              String                 @db.Uuid
  examination_number        Int
  status                    String                 @default("DRAFT") @db.VarChar(20)
  version                   Int                    @default(1)
  measured_at               DateTime               @db.Timestamptz(6)
  recorder_user_id          String                 @db.VarChar(50)
  examiner_user_id          String?                @db.VarChar(50)
  corrects_examination_id   String?                @db.Uuid
  supersedes_examination_id String?                @db.Uuid
  correction_source_version Int?
  correction_reason         String?                @db.VarChar(500)
  finalized_at              DateTime?              @db.Timestamptz(6)
  finalized_by              String?                @db.VarChar(50)
  voided_at                 DateTime?              @db.Timestamptz(6)
  voided_by                 String?                @db.VarChar(50)
  void_reason               String?                @db.VarChar(500)
  created_by                String                 @db.VarChar(50)
  updated_by                String                 @db.VarChar(50)
  created_at                DateTime               @default(now()) @db.Timestamptz(6)
  updated_at                DateTime               @default(now()) @updatedAt @db.Timestamptz(6)
  encounter                 opd_encounter          @relation(fields: [encounter_id, clinic_id, branch_id], references: [encounter_id, clinic_id, branch_id], onDelete: Restrict, onUpdate: Cascade, map: "opd_examination_encounter_tenant_fkey")
  correction_root           opd_examination?       @relation("OpdExaminationCorrectionRoot", fields: [corrects_examination_id, clinic_id, branch_id, encounter_id], references: [examination_id, clinic_id, branch_id, encounter_id], onDelete: Restrict, onUpdate: Cascade, map: "opd_examination_corrects_identity_fkey")
  correction_revisions      opd_examination[]      @relation("OpdExaminationCorrectionRoot")
  superseded_examination    opd_examination?       @relation("OpdExaminationSupersedes", fields: [supersedes_examination_id, clinic_id, branch_id, encounter_id], references: [examination_id, clinic_id, branch_id, encounter_id], onDelete: Restrict, onUpdate: Cascade, map: "opd_examination_supersedes_identity_fkey")
  superseding_examination   opd_examination?       @relation("OpdExaminationSupersedes")
  vital_observation         opd_vital_observation?
  symptom_section           opd_symptom_section?

  @@unique([examination_id, clinic_id, branch_id], map: "opd_examination_tenant_uq")
  @@unique([examination_id, clinic_id, branch_id, encounter_id], map: "opd_examination_identity_uq")
  @@unique([clinic_id, branch_id, encounter_id, examination_number], map: "opd_examination_number_uq")
  @@unique([supersedes_examination_id, clinic_id, branch_id, encounter_id], map: "opd_examination_supersedes_uq")
  @@index([clinic_id, branch_id, encounter_id, status, examination_number], map: "opd_examination_encounter_idx")
  @@index([clinic_id, branch_id, encounter_id, corrects_examination_id, examination_number], map: "opd_examination_correction_root_idx")
}

// Independently versioned one-to-one vital section. BMI is server-derived from
// weight and height; reference interpretations remain null until an approved
// versioned rule catalog exists.
model opd_vital_observation {
  vital_observation_id          String          @id @default(uuid()) @db.Uuid
  clinic_id                     String          @db.VarChar(50)
  branch_id                     String          @db.VarChar(50)
  encounter_id                  String          @db.Uuid
  examination_id                String          @db.Uuid
  weight_kg                     Decimal?        @db.Decimal(7, 2)
  height_cm                     Decimal?        @db.Decimal(7, 2)
  body_mass_index               Decimal?        @db.Decimal(5, 2)
  systolic_blood_pressure_mmhg  Int?
  diastolic_blood_pressure_mmhg Int?
  pulse_rate_per_minute         Int?
  temperature_celsius           Decimal?        @db.Decimal(4, 1)
  oxygen_saturation_percent     Decimal?        @db.Decimal(5, 2)
  respiratory_rate_per_minute   Int?
  dtx_mg_dl                     Decimal?        @db.Decimal(7, 2)
  pain_score                    Int?
  reference_rule_version        String?         @db.VarChar(50)
  interpretation_snapshot       Json?
  version                       Int             @default(1)
  created_by                    String          @db.VarChar(50)
  updated_by                    String          @db.VarChar(50)
  created_at                    DateTime        @default(now()) @db.Timestamptz(6)
  updated_at                    DateTime        @default(now()) @updatedAt @db.Timestamptz(6)
  examination                   opd_examination @relation(fields: [examination_id, clinic_id, branch_id, encounter_id], references: [examination_id, clinic_id, branch_id, encounter_id], onDelete: Restrict, onUpdate: Cascade, map: "opd_vital_observation_examination_identity_fkey")

  @@unique([examination_id, clinic_id, branch_id], map: "opd_vital_observation_examination_uq")
  @@unique([examination_id, clinic_id, branch_id, encounter_id], map: "opd_vital_observation_identity_uq")
  @@index([clinic_id, branch_id, encounter_id, examination_id], map: "opd_vital_observation_encounter_idx")
}

// Independently versioned symptom section. The examination-level patient quote
// follows the approved prototype; repeatable symptoms remain normalized rows.
model opd_symptom_section {
  symptom_section_id String          @id @default(uuid()) @db.Uuid
  clinic_id          String          @db.VarChar(50)
  branch_id          String          @db.VarChar(50)
  encounter_id       String          @db.Uuid
  examination_id     String          @db.Uuid
  patient_quote      String?         @db.VarChar(4000)
  version            Int             @default(1)
  created_by         String          @db.VarChar(50)
  updated_by         String          @db.VarChar(50)
  created_at         DateTime        @default(now()) @db.Timestamptz(6)
  updated_at         DateTime        @default(now()) @updatedAt @db.Timestamptz(6)
  examination        opd_examination @relation(fields: [examination_id, clinic_id, branch_id, encounter_id], references: [examination_id, clinic_id, branch_id, encounter_id], onDelete: Restrict, onUpdate: Cascade, map: "opd_symptom_section_examination_identity_fkey")
  symptoms           opd_symptom[]

  @@unique([symptom_section_id, clinic_id, branch_id, encounter_id], map: "opd_symptom_section_identity_uq")
  @@unique([examination_id, clinic_id, branch_id, encounter_id], map: "opd_symptom_section_examination_uq")
  @@index([clinic_id, branch_id, encounter_id, examination_id], map: "opd_symptom_section_encounter_idx")
}

model opd_symptom {
  symptom_id         String                    @id @default(uuid()) @db.Uuid
  clinic_id          String                    @db.VarChar(50)
  branch_id          String                    @db.VarChar(50)
  encounter_id       String                    @db.Uuid
  symptom_section_id String                    @db.Uuid
  display_order      Int
  main_code          String?                   @db.VarChar(50)
  main_text          String                    @db.VarChar(300)
  duration_value     Decimal?                  @db.Decimal(10, 2)
  duration_unit      String?                   @db.VarChar(30)
  location           String?                   @db.VarChar(200)
  laterality         String?                   @db.VarChar(20)
  severity           Int?
  character          String?                   @db.VarChar(200)
  modifying_factors  String?                   @db.VarChar(1000)
  staff_summary      String?                   @db.VarChar(4000)
  created_by         String                    @db.VarChar(50)
  updated_by         String                    @db.VarChar(50)
  created_at         DateTime                  @default(now()) @db.Timestamptz(6)
  updated_at         DateTime                  @default(now()) @updatedAt @db.Timestamptz(6)
  symptom_section    opd_symptom_section       @relation(fields: [symptom_section_id, clinic_id, branch_id, encounter_id], references: [symptom_section_id, clinic_id, branch_id, encounter_id], onDelete: Cascade, onUpdate: Cascade, map: "opd_symptom_section_identity_fkey")
  associations       opd_symptom_association[]

  @@unique([symptom_id, clinic_id, branch_id, encounter_id], map: "opd_symptom_identity_uq")
  @@unique([symptom_section_id, display_order], map: "opd_symptom_order_uq")
  @@index([clinic_id, branch_id, encounter_id, symptom_section_id], map: "opd_symptom_section_idx")
}

model opd_symptom_association {
  symptom_association_id String      @id @default(uuid()) @db.Uuid
  clinic_id              String      @db.VarChar(50)
  branch_id              String      @db.VarChar(50)
  encounter_id           String      @db.Uuid
  symptom_id             String      @db.Uuid
  display_order          Int
  code                   String?     @db.VarChar(50)
  label                  String      @db.VarChar(200)
  created_at             DateTime    @default(now()) @db.Timestamptz(6)
  symptom                opd_symptom @relation(fields: [symptom_id, clinic_id, branch_id, encounter_id], references: [symptom_id, clinic_id, branch_id, encounter_id], onDelete: Cascade, onUpdate: Cascade, map: "opd_symptom_association_symptom_identity_fkey")

  @@unique([symptom_id, display_order], map: "opd_symptom_association_order_uq")
  @@index([clinic_id, branch_id, encounter_id, symptom_id], map: "opd_symptom_association_symptom_idx")
}

// Encounter-level diagnosis section stays DRAFT until the future confirm-cure
// command. Code/system/edition/label are immutable snapshots, not FKs to a
// mutable external catalog.
model opd_diagnosis_section {
  diagnosis_section_id String          @id @default(uuid()) @db.Uuid
